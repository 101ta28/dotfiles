# This is Git's per-user configuration file.
[user]
	name = 101ta28
	email = workta28@gmail.com
[credential]
	helper = /usr/local/share/gcm-core/git-credential-manager-core
	credentialStore = secretservice
[credential "https://dev.azure.com"]
	useHttpPath = true
[alias]
	cm = "commit"
	co = "checkout"
	br = "branch"
	sw = "switch"
	# プルリクをローカルに持ってくるコマンド
	# git cpr <プルリク番号>
	cpr = "!f(){ git fetch origin pull/$1/head:pr-$1; git checkout pr-$1; };f"
[init]
	defaultBranch = main
